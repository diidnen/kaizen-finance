**/target/**

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Application properties with secrets (use environment variables instead)
# application.properties should not contain real API keys

